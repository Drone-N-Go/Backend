# =============================================================================
# Drone N' Go API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# For Railway PostgreSQL, go to your service → Connect tab → copy the URL.
# Change the prefix from postgresql:// to postgresql+asyncpg://
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql+asyncpg://USER:PASSWORD@HOST.railway.app:PORT/railway"

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET="REPLACE_WITH_64_CHAR_HEX_STRING"

# -----------------------------------------------------------------------------
# ADMIN SEED ACCOUNT
# Created automatically on first startup if it does not exist.
# -----------------------------------------------------------------------------
ADMIN_EMAIL="james@droneandgo.io"
ADMIN_PASSWORD="REPLACE_WITH_SECURE_PASSWORD"

# -----------------------------------------------------------------------------
# SMIOTA WEBHOOK API KEY
# This key is verified via HTTP Basic Auth on POST /api/webhooks/smiota
# Username = API key, Password = empty (industry standard)
# -----------------------------------------------------------------------------
SMIOTA_API_KEY="REPLACE_WITH_SMIOTA_API_KEY"

# -----------------------------------------------------------------------------
# CORS
# In production, replace * with your mobile app / frontend origin(s).
# Example: "https://app.droneandgo.io,https://admin.droneandgo.io"
# -----------------------------------------------------------------------------
CORS_ORIGINS="*"

# -----------------------------------------------------------------------------
# AWS S3 — FILE UPLOADS
# All drone condition images are stored in S3.
# Create an IAM user with AmazonS3FullAccess (or a scoped bucket policy).
# See docs/aws-s3-setup.md for step-by-step instructions.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID="REPLACE_WITH_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="REPLACE_WITH_AWS_SECRET_ACCESS_KEY"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="REPLACE_WITH_YOUR_BUCKET_NAME"

# -----------------------------------------------------------------------------
# SERVER (optional overrides)
# -----------------------------------------------------------------------------
APP_ENV="development"   # development | production
PORT=8000
